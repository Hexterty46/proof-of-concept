<section class="product-gallery" aria-label="Productafbeeldingen">
  <section class="main-section-images">
    {% assign firstImage = imageUrls[1] %}
    {% if firstImage %}
      <figure>
        <a
          href="{{ firstImage }}"
          data-full="{{ firstImage }}"
          class="product-main-link"
        >
          <picture>
            <source
              type="image/avif"
              srcset="{{ firstImage }}?fit=cover&format=avif&width=400&quality=80"
            >
            <source
              type="image/webp"
              srcset="{{ firstImage }}?fit=cover&format=webp&width=400&quality=80"
            >
            <img
              class="product-main-image"
              src="{{ firstImage }}?fit=cover&width=400&quality=80"
              alt="{{ product.title }}"
              id="main-image"
            >
          </picture>
        </a>
      </figure>
    {% endif %}
  </section>

  <section class="sub-section-images" aria-label="Extra productafbeeldingen">
    <ul>
      {% for url in imageUrls reversed offset: 1 %}
        <li>
          <a href="{{ url }}" data-full="{{ url }}" class="{% if forloop.first %}is-active{% endif %}">
            <picture>
              <source
                type="image/avif"
                srcset="{{ url }}?fit=cover&format=avif&width=400&quality=80"
              >
              <source
                type="image/webp"
                srcset="{{ url }}?fit=cover&format=webp&width=400&quality=80"
              >
              <img
                src="{{ url }}?fit=cover&width=400&quality=80"
                alt="{{ product.title }} afbeelding {{ forloop.index }}"
                loading="lazy"
              >
            </picture>
          </a>
        </li>
      {% endfor %}
    </ul>
  </section>
</section>
